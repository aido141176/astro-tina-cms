---
const { title = "My Site" } = Astro.props;
---

<nav class="bg-white/80 backdrop-blur border-b sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex justify-between h-16 items-center">
      
      <!-- Logo -->
      <div class="text-xl font-bold">
        {title}
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex space-x-6">
        <a href="/" class="text-gray-700 hover:text-blue-600">Home</a>
        <a href="/about" class="text-gray-700 hover:text-blue-600">About</a>
        <a href="/services" class="text-gray-700 hover:text-blue-600">Services</a>
        <a href="/contact" class="text-gray-700 hover:text-blue-600">Contact</a>
      </div>

      <!-- Mobile Button -->
      <button id="menu-btn" class="md:hidden text-gray-700">
        ☰
      </button>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden px-4 pb-4">
    <a href="/" class="block py-2">Home</a>
    <a href="/about" class="block py-2">About</a>
    <a href="/services" class="block py-2">Services</a>
    <a href="/contact" class="block py-2">Contact</a>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>