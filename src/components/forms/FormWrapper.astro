---
type Field = {
  name: string;
  label: string;
  type: "text" | "email" | "number" | "date" | "textarea" | "select";
  required?: boolean;
  options?: string[];
};

const { config, formType = "contact" } = Astro.props as {
  config: { fields: Field[] };
  formType?: string;
};
---

<form id="form" class="space-y-4 max-w-xl">

  {config.fields.map((field: Field) => {
    if (field.type === "textarea") {
      return (
        <textarea
          name={field.name}
          placeholder={field.label}
          required={field.required}
          class="w-full p-3 border rounded"
        ></textarea>
      );
    }

    if (field.type === "select") {
      return (
        <select
          name={field.name}
          required={field.required}
          class="w-full p-3 border rounded"
        >
          <option value="">Select {field.label}</option>
          {field.options?.map((opt: string) => (
            <option value={opt}>{opt}</option>
          ))}
        </select>
      );
    }

    // Input types
    if (
      field.type === "text" ||
      field.type === "email" ||
      field.type === "number" ||
      field.type === "date"
    ) {
      return (
        <input
          type={field.type}
          name={field.name}
          placeholder={field.label}
          required={field.required}
          class="w-full p-3 border rounded"
        />
      );
    }

    return null;
  })}

  <!-- Hidden -->
  <input type="hidden" name="formType" value={formType} />

  <!-- Submit -->
  <button
    type="submit"
    id="submitBtn"
    class="px-6 py-3 text-white bg-blue-600 rounded"
  >
    Send
  </button>

  <!-- Status -->
  <p id="status" class="text-sm"></p>
</form>

<script>
  const form = document.getElementById("form");
  const status = document.getElementById("status");
  const button = document.getElementById("submitBtn");

  if (form instanceof HTMLFormElement && status && button) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      status.textContent = "Sending...";
      button.setAttribute("disabled", "true");

      const formData = new FormData(form);

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          body: formData,
        });

        if (res.ok) {
          status.textContent = "✅ Message sent!";
          form.reset();
        } else {
          status.textContent = "❌ Something went wrong.";
        }
      } catch (err) {
        status.textContent = "❌ Network error.";
      }

      button.removeAttribute("disabled");
    });
  }
</script>