---
import FormField from "./FormField.astro";
import FormSelect from "./FormSelect.astro";
import FormTextarea from "./FormTextarea.astro";

type Field = {
  name: string;
  label: string;
  type: "text" | "email" | "number" | "date" | "textarea" | "select";
  required?: boolean;
  options?: string[];
  grid?: "half" | "full";
};

const { config, formType = "contact" } = Astro.props as {
  config: { fields: Field[] };
  formType?: string;
};
---

<form id="form" class="max-w-2xl p-8 mx-auto bg-white border border-gray-100 shadow-lg rounded-2xl">

  <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
    
    {config.fields.map((field: Field) => {
      const colSpan = field.grid === "full" ? "md:col-span-2" : "";

      if (field.type === "textarea") {
        return (
          <div class={colSpan}>
            <FormTextarea field={field} />
          </div>
        );
      }

      if (field.type === "select") {
        return (
          <div class={colSpan}>
            <FormSelect field={field} />
          </div>
        );
      }

      return (
        <div class={colSpan}>
          <FormField field={field} />
        </div>
      );
    })}

  </div>

  <input type="hidden" name="formType" value={formType} />

  <button
    type="submit"
    id="submitBtn"
     class="w-full py-4 mt-6 font-semibold text-white transition duration-200 shadow-md rounded-xl bg-linear-to-r from-blue-600 to-blue-500 hover:from-blue-700 hover:to-blue-600 hover:shadow-lg"
  >
    Send Booking Request
  </button>

    <p id="status" class="mt-3 text-sm text-gray-600"></p>
</form>

<script>
  const form = document.getElementById("form");
  const status = document.getElementById("status");
  const button = document.getElementById("submitBtn");

  if (form instanceof HTMLFormElement && status && button) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      status.textContent = "Sending...";
      button.setAttribute("disabled", "true");

      const formData = new FormData(form);

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          body: formData,
        });

        if (res.ok) {
          status.textContent = "✅ Message sent!";
          form.reset();
        } else {
          status.textContent = "❌ Something went wrong.";
        }
      } catch (err) {
        status.textContent = "❌ Network error.";
      }

      button.removeAttribute("disabled");
    });
  }
</script>