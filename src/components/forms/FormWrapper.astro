---
import FormField from "./FormField.astro";
import FormSelect from "./FormSelect.astro";
import FormTextarea from "./FormTextarea.astro";

type Field = {
  name: string;
  label: string;
  type: "text" | "email" | "number" | "date" | "textarea" | "select";
  required?: boolean;
  options?: string[];
};

const { config, formType = "contact" } = Astro.props as {
  config: { fields: Field[] };
  formType?: string;
};
---

<form id="form" class="max-w-xl space-y-4">

  {config.fields.map((field: Field) => {
    if (field.type === "textarea") {
      return <FormTextarea field={field} />;
    }

    if (field.type === "select") {
      return <FormSelect field={field} />;
    }

    return <FormField field={field} />;
  })}

  <input type="hidden" name="formType" value={formType} />

  <button
    type="submit"
    id="submitBtn"
    class="px-6 py-3 text-white bg-blue-600 rounded"
  >
    Send
  </button>

  <p id="status" class="text-sm"></p>
</form>

<script>
  const form = document.getElementById("form");
  const status = document.getElementById("status");
  const button = document.getElementById("submitBtn");

  if (form instanceof HTMLFormElement && status && button) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      status.textContent = "Sending...";
      button.setAttribute("disabled", "true");

      const formData = new FormData(form);

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          body: formData,
        });

        if (res.ok) {
          status.textContent = "✅ Message sent!";
          form.reset();
        } else {
          status.textContent = "❌ Something went wrong.";
        }
      } catch (err) {
        status.textContent = "❌ Network error.";
      }

      button.removeAttribute("disabled");
    });
  }
</script>