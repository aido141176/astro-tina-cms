---
const { title = "My Site" } = Astro.props;
---

<nav class="bg-white shadow-md">
  <div class="px-4 mx-auto max-w-7xl">
    <div class="flex items-center justify-between h-16">
      
      <!-- Logo -->
      <div class="text-xl font-bold">
        {title}
      </div>

      <!-- Desktop Menu -->
      <div class="hidden space-x-6 md:flex">
        <a href="/" class="text-gray-700 hover:text-blue-600">Home</a>
        <a href="/about" class="text-gray-700 hover:text-blue-600">About</a>

        <!-- Dropdown -->
        <div class="relative">
          <button 
            id="services-btn"
            class="flex items-center gap-1 text-gray-700 hover:text-blue-600"
          >
            Services
            <span>▾</span>
          </button>

          <div 
            id="services-menu"
            class="absolute hidden w-40 mt-2 bg-white rounded shadow-md"
          >
            <a href="/web" class="block px-4 py-2 hover:bg-gray-100">Web Design</a>
            <a href="/seo" class="block px-4 py-2 hover:bg-gray-100">SEO</a>
          </div>
        </div>

        <a href="/contact" class="text-gray-700 hover:text-blue-600">Contact</a>
      </div>

      <!-- Mobile Button -->
      <button id="menu-btn" class="text-gray-700 md:hidden">
        ☰
      </button>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden px-4 pb-4 md:hidden">
    <a href="/" class="block py-2">Home</a>
    <a href="/about" class="block py-2">About</a>
    <a href="/services" class="block py-2">Services</a>
    <a href="/contact" class="block py-2">Contact</a>
  </div>
</nav>

<script is:inline>
  const script = document.currentScript;
  if (!script) return;

  const root = script.closest("nav");
  if (!root) return;

  // Mobile menu
  const menuBtn = root.querySelector("#menu-btn");
  const mobileMenu = root.querySelector("#mobile-menu");

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener("click", () => {
      mobileMenu.classList.toggle("hidden");
    });
  }

  // Dropdown
  const dropdownBtn = root.querySelector("#services-btn");
  const dropdownMenu = root.querySelector("#services-menu");

  if (dropdownBtn && dropdownMenu) {
    dropdownBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdownMenu.classList.toggle("hidden");
    });

    document.addEventListener("click", (e) => {
      if (
        !dropdownBtn.contains(e.target) &&
        !dropdownMenu.contains(e.target)
      ) {
        dropdownMenu.classList.add("hidden");
      }
    });
  }
</script>