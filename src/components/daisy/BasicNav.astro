---
const { title = "My Site" } = Astro.props;
---

<nav class="bg-white shadow-md">
  <div class="px-4 mx-auto max-w-7xl">
    <div class="flex items-center justify-between h-16">
      
      <!-- Logo -->
      <div class="text-xl font-bold">
        {title}
      </div>

      <!-- Desktop Menu -->
      <div class="items-center hidden space-x-6 md:flex">
        <a href="/" class="text-gray-700 hover:text-blue-600">Home</a>
        <a href="/about" class="text-gray-700 hover:text-blue-600">About</a>

        <!-- Dropdown -->
        <div class="relative">
          <button class="flex items-center gap-1 text-gray-700 services-btn">
            Services <span>▾</span>
          </button>

          <div class="absolute hidden w-40 mt-2 bg-white rounded shadow-md services-menu">
            <a href="/web" class="block px-4 py-2 hover:bg-gray-100">Web Design</a>
            <a href="/seo" class="block px-4 py-2 hover:bg-gray-100">SEO</a>
          </div>
        </div>

        <a href="/contact" class="text-gray-700 hover:text-blue-600">Contact</a>
      </div>

      <!-- Mobile Button -->
      <button class="text-gray-700 mobile-btn md:hidden">
        ☰
      </button>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="hidden px-4 pb-4 mobile-menu md:hidden">
    <a href="/" class="block py-2">Home</a>
    <a href="/about" class="block py-2">About</a>
    <a href="/contact" class="block py-2">Contact</a>
  </div>
</nav>

<script>
  (() => {
    const nav = document.currentScript.closest('nav');
    if (!nav) return;

    // Mobile menu
    const mobileBtn = nav.querySelector('.mobile-btn');
    const mobileMenu = nav.querySelector('.mobile-menu');

    mobileBtn?.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Dropdown
    const dropdownBtn = nav.querySelector('.services-btn');
    const dropdownMenu = nav.querySelector('.services-menu');

    dropdownBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdownMenu.classList.toggle('hidden');
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!nav.contains(e.target)) {
        dropdownMenu?.classList.add('hidden');
      }
    });
  })();
</script>